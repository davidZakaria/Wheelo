[Unit]
Description=Wheelo Green Avenue Roulette (Streamlit)
After=network.target

[Service]
Type=simple
User=YOUR_LINUX_USER
Group=YOUR_LINUX_USER
WorkingDirectory=/var/www/wheelo
Environment=PYTHONUNBUFFERED=1
ExecStart=/var/www/wheelo/.venv/bin/python -m streamlit run app.py --server.port 8503 --server.address 127.0.0.1 --server.headless true
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
